# Azure AD / Entra ID — only the app's client ID is required for interactive login
CLIENT_ID=your-client-id-here

# Optional: your tenant ID. If omitted, any work/school account can log in.
# TENANT_ID=your-tenant-id-here

# Microsoft Teams identifiers
TEAM_ID=your-team-id-here
CHANNEL_ID=your-channel-id-here
